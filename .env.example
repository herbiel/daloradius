# Copy to .env and adjust values before running: cp .env.example .env
# Docker Compose loads .env automatically for variable substitution.

# --- MariaDB (radius-mysql) ---
MYSQL_DATABASE=radius
MYSQL_USER=radius
MYSQL_PASSWORD=radiusdbpw
MYSQL_ROOT_PASSWORD=radiusrootdbpw

# --- Database connection (radius, radius-web) ---
# MYSQL_HOST is the Docker Compose service name; change only if you rename the service.
MYSQL_HOST=radius-mysql
MYSQL_PORT=3306

# --- FreeRADIUS ---
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
DEFAULT_CLIENT_SECRET=testing123
DEFAULT_FREERADIUS_SERVER=radius
# WiFi 802.1X default EAP method (peap for Windows/iOS; md5 only for legacy clients).
RADIUS_DEFAULT_EAP_TYPE=peap
# Host path mounted into the radius container for PEAP/TTLS TLS certs (read-only).
# Place privkey.pem + fullchain.pem here (e.g. from acme.sh --install-cert).
RADIUS_CERT_HOST_DIR=/opt/radius-certs
# acme.sh example reloadcmd (adjust the cd path to this repo on the host):
# --reloadcmd "cd /path/to/daloradius && docker compose restart radius"

# --- daloRADIUS web UI ---
WEB_PORT=801

# --- Mail (optional) ---
MAIL_SMTPADDR=xxxx
MAIL_PORT=465
MAIL_AUTH=login
MAIL_FROM=xxxx
MAIL_ENABLED=yes
MAIL_SMTP_SECURITY=ssl
MAIL_SMTP_SENDER_NAME=Vpn Connect System
MAIL_SMTP_SUBJECT_PREFIX=[VpnSystem]
MAIL_SMTP_USERNAME=xxxx
MAIL_SMTP_PASSWORD=xxxxx
# Optional note appended to all outgoing emails (after the main body).
# Use \n for line breaks; basic HTML is supported.
MAIL_BODY_NOTE=

# --- VPN ---
USER_VPN_SERVER=xxxx
